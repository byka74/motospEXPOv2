{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "jsx": "react-native",
    "moduleResolution": "node",
    "baseUrl": "./",
    "paths": {
      "@/*": ["./*"]
    },
    "checkJs": false, // JSDoc-ийг идэвхжүүлэх
    "allowJs": true, // JS файл дээр ажиллахыг зөвшөөрөх
    "resolveJsonModule": true // JSON файлуудаас suggest авах
  },
  "exclude": ["node_modules", "android", "ios", ".expo"]
}
